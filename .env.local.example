# Wallet — Shipyard connects to the user's wallet (MetaMask, Rabby, etc.) via
# WalletConnect/RainbowKit. Shipyard never receives or stores private keys;
# all transactions are signed in the user's wallet.
# Get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# OpenRouter — used for AI contract generation
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: default model for AI generation. Falls back to qwen/qwen3-coder if not set.
NEXT_PUBLIC_DEFAULT_AI_MODEL=qwen/qwen3-coder

# Supabase — server-side only (no NEXT_PUBLIC_ prefix). Get these from the
# Supabase dashboard: Project Settings -> API. The service_role key bypasses RLS
# and must NEVER be exposed to the client. Leave blank to run without a database.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Only needed to run migrations (supabase db push). Use the dashboard's
# "Session pooler" connection string (the direct db.<ref> host is IPv6-only).
# Contains the DB password — never commit a real value.
SUPABASE_DB_URL=

# First-party analytics — server-side salt used to hash wallet addresses before
# storage (raw wallets are never stored). Set to any long random string.
ANALYTICS_SALT=

# SIWE auth — secret used to sign the session JWT stored in an httpOnly cookie.
# Set to a long random string (e.g. `openssl rand -hex 32`).
SESSION_SECRET=

# Upstash Redis — serverless cache / rate-limiting / nonce store (server-side only).
# From console.upstash.com (REST API section) or the Vercel Upstash integration.
# Leave blank to run without Redis (features degrade gracefully).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
